+cp /${ARCH_DIR}/bin/rm ${BINDIR}/rm
+chmod 755 ${BINDIR}/blood-elf
+chmod 755 ${BINDIR}/bake
+chmod 755 ${BINDIR}/catm
+chmod 755 ${BINDIR}/chmod
+chmod 755 ${BINDIR}/cp
