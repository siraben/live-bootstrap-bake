+    int start;
+    int stop;
+    int components;
+    int out_size;
+    char *path;
+
+    start = 0;
+    while(start < size &&
+          (line[start] == ' ' || line[start] == '\t')) {
+        start = start + 1;
+    }
+
+    if(starts_with(line + start, size - start, "/dev/null")) {
+        writestr_fd(2, "Creating or deleting files is not supported\n");
+        exit(1);
+    }
+
+    components = 0;
+    while(start < size && components < strip) {
+        if(line[start] == '/') {
+            components = components + 1;
+        }
+        start = start + 1;
+    }
+
+    stop = start;
+    while(stop < size &&
+          line[stop] != ' ' &&
+          line[stop] != '\t' &&
+          line[stop] != '\n') {
+        stop = stop + 1;
+    }
