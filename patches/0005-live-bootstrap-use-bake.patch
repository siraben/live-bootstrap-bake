diff --git a/steps/gzip-1.2.4/pass1.bake b/steps/gzip-1.2.4/pass1.bake
new file mode 100644
index 0000000..1a42af1
--- /dev/null
+++ b/steps/gzip-1.2.4/pass1.bake
@@ -0,0 +1,31 @@
+: all build checksum
+
+: build
+checksum-transcriber sources
+sha256sum -c sources.SHA256SUM
+mkdir build
+cd build
+ungz --file ${DISTFILES}/${pkg}.tar.gz --output ${pkg}.tar
+untar --file ${pkg}.tar
+rm ${pkg}.tar
+cd ${pkg}
+cp ../../mk/main.mk Makefile
+catm gzip.c.new ../../files/stat_override.c gzip.c
+cp gzip.c.new gzip.c
+patch -Np1 -i ../../patches/removecrc.patch
+patch -Np1 -i ../../patches/makecrc-write-to-file.patch
+tcc -static -o makecrc sample/makecrc.c
+./makecrc
+catm util.c.new util.c crc.c
+cp util.c.new util.c
+make
+cp gzip ${BINDIR}/gzip
+cp gzip ${BINDIR}/gunzip
+chmod 755 ${BINDIR}/gzip
+chmod 755 ${BINDIR}/gunzip
+cd ../..
+
+: checksum build
+? UPDATE_CHECKSUMS True sha256sum -o ${pkg}.checksums /usr/bin/gzip
+? UPDATE_CHECKSUMS True cp ${pkg}.checksums ${SRCDIR}
+! UPDATE_CHECKSUMS True sha256sum -c ${pkg}.checksums
