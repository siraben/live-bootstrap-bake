+
+: build
+checksum-transcriber sources
+sha256sum -c sources.SHA256SUM
+mkdir build
+cd build
+unbz2 --file ${DISTFILES}/${pkg}.tar.bz2 --output ${pkg}.tar
+ungz --file ${DISTFILES}/${MES_PKG}.tar.gz --output ${MES_PKG}.tar
+untar --file ${pkg}.tar
+simple-patch -Np0 -i ../patches/remove-fileopen.patch
+simple-patch -Np0 -i ../patches/addback-fileopen.patch
+simple-patch -Np0 -i ../patches/fiwix-paddr.patch
+simple-patch -Np0 -i ../patches/check-reloc-null.patch
+untar --non-strict --file ${MES_PKG}.tar
+cd ${pkg}
+catm config.h
+tcc-0.9.26 -o ${BINDIR}/tcc ${TCC27_FLAGS} tcc.c
+cd ../${MES_PKG}
+cd lib
+catm ../unified-libc.c ${UNIFIED_LIBC_FILES}
+cd ..
+tcc -c ${MES_TCC_FLAGS} -o ${LIBDIR}/crt1.o lib/linux/x86-mes-gcc/crt1.c
+tcc -c ${MES_TCC_FLAGS} -o ${LIBDIR}/crtn.o lib/linux/x86-mes-gcc/crtn.c
+tcc -c ${MES_TCC_FLAGS} -o ${LIBDIR}/crti.o lib/linux/x86-mes-gcc/crti.c
+tcc -c ${MES_TCC_FLAGS} -D HAVE_LONG_LONG_STUB=1 lib/libtcc1.c
+tcc -c -D TCC_TARGET_I386=1 ../${pkg}/lib/libtcc1.c
+tcc -ar cr ${LIBDIR}/tcc/libtcc1.a libtcc1.o
+tcc -c ${MES_TCC_FLAGS} -o unified-libc.o unified-libc.c
+tcc -ar cr ${LIBDIR}/libc.a unified-libc.o
+cd ../..
+tcc -version
+
+: checksum build
+? UPDATE_CHECKSUMS True sha256sum -o ${pkg}.checksums /usr/bin/tcc
+? UPDATE_CHECKSUMS True cp ${pkg}.checksums ${SRCDIR}
+! UPDATE_CHECKSUMS True sha256sum -c ${pkg}.checksums
