: all build checksum

: build
M2-Mesoplanet --architecture ${ARCH} -o ${BINDIR}/checksum-transcriber src/checksum-transcriber.c

: checksum build
? UPDATE_CHECKSUMS True sha256sum -o ${pkg}.${ARCH}.checksums /usr/bin/checksum-transcriber
? UPDATE_CHECKSUMS True cp ${pkg}.${ARCH}.checksums ${SRCDIR}
! UPDATE_CHECKSUMS True sha256sum -c ${pkg}.${ARCH}.checksums
