: all sha256sum match mkdir untar ungz unbz2 unxz catm cp chmod rm replace wrap
: sha256sum match mkdir untar ungz unbz2 unxz catm cp chmod rm replace wrap :
export M2LIBC_PATH ${M2LIBC}
export PATH ${TOOLS}
${TOOLS}/M2-Mesoplanet --operating-system ${OPERATING_SYSTEM} --architecture ${ARCH} -o ${BINDIR}/$@ $@.c
